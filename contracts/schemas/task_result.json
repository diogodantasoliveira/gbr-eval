{
  "$defs": {
    "GraderResult": {
      "properties": {
        "grader_type": {
          "title": "Grader Type",
          "type": "string"
        },
        "field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "weight": {
          "default": 1.0,
          "title": "Weight",
          "type": "number"
        },
        "required": {
          "default": false,
          "title": "Required",
          "type": "boolean"
        },
        "details": {
          "default": "",
          "title": "Details",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        },
        "severity": {
          "anyOf": [
            {
              "$ref": "#/$defs/Severity"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "file_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File Path"
        }
      },
      "required": [
        "grader_type",
        "passed",
        "score"
      ],
      "title": "GraderResult",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "properties": {
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "passed": {
      "title": "Passed",
      "type": "boolean"
    },
    "score": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Score",
      "type": "number"
    },
    "grader_results": {
      "items": {
        "$ref": "#/$defs/GraderResult"
      },
      "title": "Grader Results",
      "type": "array"
    },
    "duration_ms": {
      "default": 0.0,
      "title": "Duration Ms",
      "type": "number"
    },
    "pass_threshold": {
      "default": 0.95,
      "title": "Pass Threshold",
      "type": "number"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    },
    "golden_set_tags": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Golden Set Tags"
    },
    "reducer_scores": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Reducer Scores",
      "type": "object"
    },
    "epoch_scores": {
      "items": {
        "type": "number"
      },
      "title": "Epoch Scores",
      "type": "array"
    }
  },
  "required": [
    "task_id",
    "passed",
    "score",
    "grader_results"
  ],
  "title": "TaskResult",
  "type": "object"
}
