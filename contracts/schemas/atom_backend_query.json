  "components": {
    "schemas": {
      "BulkApproveRequest": {
        "properties": {
          "audit_id": {
            "type": "string",
            "format": "uuid",
            "title": "Audit Id"
          },
          "threshold": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Threshold",
            "description": "Minimum confidence to auto-approve"
          }
        },
        "type": "object",
        "required": [
          "audit_id",
          "threshold"
        ],
        "title": "BulkApproveRequest",
        "description": "Request to auto-approve items above a confidence threshold."
      },
      "BulkApproveResponse": {
        "properties": {
          "approved_count": {
            "type": "integer",
            "title": "Approved Count"
          },
          "skipped_count": {
            "type": "integer",
            "title": "Skipped Count"
          },
          "total_evaluated": {
            "type": "integer",
            "title": "Total Evaluated"
          }
        },
        "type": "object",
        "required": [
          "approved_count",
          "skipped_count",
          "total_evaluated"
        ],
        "title": "BulkApproveResponse",
        "description": "Response for bulk approve operation."
      },
      "ConfirmRequest": {
        "properties": {
          "notas": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1024
              },
              {
                "type": "null"
              }
            ],
            "title": "Notas",
            "description": "Optional reviewer notes"
          }
        },
        "type": "object",
        "title": "ConfirmRequest",
        "description": "Body for confirming an extraction as correct."
      },
      "CorrectRequest": {
        "properties": {
          "valor_corrigido": {
            "additionalProperties": true,
            "type": "object",
            "title": "Valor Corrigido",
            "description": "The corrected value"
          },
          "notas": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1024
              },
              {
                "type": "null"
              }
            ],
            "title": "Notas",
            "description": "Optional reviewer notes"
          }
        },
        "type": "object",
        "required": [
          "valor_corrigido"
        ],
        "title": "CorrectRequest",
        "description": "Body for correcting an extracted value."
      },
      "DecisionItem": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "item_id": {
            "type": "string",
            "title": "Item Id"
          },
          "tenant_id": {
            "type": "string",
            "title": "Tenant Id"
          },
          "action": {
            "type": "string",
            "title": "Action"
          },
          "reviewed_by": {
            "type": "string",
            "title": "Reviewed By"
          },
          "delegated_to": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Delegated To"
          },
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "item_id",
          "tenant_id",
          "action",
          "reviewed_by",
          "delegated_to",
          "reason",
          "created_at"
        ],
        "title": "DecisionItem"
      },
      "DecisionsListResponse": {
        "properties": {
