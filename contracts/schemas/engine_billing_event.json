        "title": "AdapterHealthStatus"
      },
      "AsyncQueryRequest": {
        "properties": {
          "tenant_id": {
            "type": "string",
            "title": "Tenant Id"
          },
          "engine": {
            "type": "string",
            "title": "Engine"
          },
          "action": {
            "type": "string",
            "title": "Action"
          },
          "input_data": {
            "additionalProperties": true,
            "type": "object",
            "title": "Input Data"
          },
