            "title": "Callback Url"
          },
          "metadata": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metadata",
            "default": {}
          }
        },
        "type": "object",
        "required": [
          "tenant_id",
          "engine",
          "action",
          "input_data",
          "callback_url"
        ],
        "title": "AsyncQueryRequest",
        "description": "Request body for async integration queries."
      },
      "FlowType": {
        "type": "string",
        "enum": [
          "sync",
          "async",
          "polling",
          "passthrough"
        ],
        "title": "FlowType",
        "description": "Integration flow pattern.\n\nPorted from engine-integracao ``src/domain_configs/base.py:FlowType``.\n\n- SYNC:        request/response in a single HTTP round-trip.\n- ASYNC:       fire-and-forget creation; result arrives via webhook.\n- POLLING:     periodic status checks until a final status is reached.\n- PASSTHROUGH: receive an external webhook event and forward it."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
