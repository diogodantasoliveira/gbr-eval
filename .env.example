# gbr-eval environment variables
# Copy to .env and fill in values

# Required for LLM-judge grader (optional for deterministic-only evals)
ANTHROPIC_API_KEY=your-api-key-here

# Golden set storage (required for `gbr-eval run --suite` against real data)
# Supports: s3://bucket/path, gs://bucket/path, or local file:///absolute/path
# Tests use local fixtures and do NOT require this variable
GBR_EVAL_GOLDEN_STORE=s3://gbr-eval-golden-sets/v1/

# Model for synthetic golden set generation (optional, default: claude-sonnet-4-5-20250929)
GBR_EVAL_SYNTH_MODEL=claude-sonnet-4-5-20250929
